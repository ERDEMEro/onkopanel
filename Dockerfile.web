FROM node:24-alpine AS builder
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /workspace

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json tsconfig.json ./

COPY lib/db/package.json                        ./lib/db/
COPY lib/api-spec/package.json                  ./lib/api-spec/
COPY lib/api-zod/package.json                   ./lib/api-zod/
COPY lib/api-client-react/package.json          ./lib/api-client-react/
COPY artifacts/onkoloji-dashboard/package.json  ./artifacts/onkoloji-dashboard/

RUN pnpm install --frozen-lockfile --ignore-scripts

COPY lib/db/                        ./lib/db/
COPY lib/api-spec/                  ./lib/api-spec/
COPY lib/api-zod/                   ./lib/api-zod/
COPY lib/api-client-react/          ./lib/api-client-react/
COPY artifacts/onkoloji-dashboard/  ./artifacts/onkoloji-dashboard/

RUN cd lib/db            && npx tsc --build --skipLibCheck 2>/dev/null || npx tsc --build --skipLibCheck --force
RUN cd lib/api-spec      && npx tsc --build --skipLibCheck 2>/dev/null || true
RUN cd lib/api-zod       && npx tsc --build --skipLibCheck 2>/dev/null || true
RUN cd lib/api-client-react && npx tsc --build --skipLibCheck 2>/dev/null || true

ARG BASE_PATH=/
ENV PORT=3000 BASE_PATH=${BASE_PATH} NODE_ENV=production

RUN pnpm --filter @workspace/onkoloji-dashboard run build

FROM nginx:1.27-alpine AS production
COPY --from=builder /workspace/artifacts/onkoloji-dashboard/dist/public /usr/share/nginx/html
COPY artifacts/onkoloji-dashboard/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
